<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".ui.theme.Screens.Sura_Details.Sura_Details_Activity"
    android:padding="16dp">

    <View
        android:id="@+id/status_bar_gold"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:background="@color/gold"
         />

    <ImageView
        android:id="@+id/back_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/suraNameEn"
        app:layout_constraintBottom_toBottomOf="@id/suraNameEn"
        />
    <ImageView
        android:id="@+id/leftcornen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ritght_corner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/suraNameEn"
        android:layout_marginTop="10dp"
        />
    <ImageView
        android:id="@+id/rightcorner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/left_corner"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/leftcornen"

        />
    <TextView
        android:id="@+id/suraNameAr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="الفاتحة"
        style="@style/titelLarge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/leftcornen"
        app:layout_constraintBottom_toBottomOf="@id/leftcornen"
        />
    <TextView
        android:id="@+id/suraNameEn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Al-Fatiha"
        style="@style/titelLarge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/status_bar_gold"
        android:layout_marginTop="8dp"
        />
    <ScrollView
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/leftcornen"
        app:layout_constraintBottom_toBottomOf="parent"
        >
        <TextView
            android:id="@+id/sura_Details"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:text=" عن أمـيـر المؤمنـين أبي حـفص عمر بن الخطاب رضي الله عنه ، قال : سمعت رسول الله صلى الله عـليه وسلم يـقـول : ( إنـما الأعـمـال بالنيات وإنـمـا لكـل امـرئ ما نـوى . فمن كـانت هجرته إلى الله ورسولـه فهجرتـه إلى الله ورسـوله ومن كانت هجرته لـدنيا يصـيبها أو امرأة ينكحها فهجرته إلى ما هاجر إليه )."
            style="@style/titelMedium"
            android:gravity="center|top"
            />
    </ScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>