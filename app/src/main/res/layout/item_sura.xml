<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginTop="10dp">

    <TextView
        android:id="@+id/suranumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/sura_number_frame"
        android:gravity="center"
        style="@style/bodyMedium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/suraNameEn"
        app:layout_constraintTop_toTopOf="parent"
        />
    <TextView
        android:id="@+id/suraNameEn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/suranumber"

        style="@style/bodyLarge"
        android:layout_marginLeft="10dp"
        app:layout_constraintTop_toTopOf="@id/suranumber"
        />
    <TextView
        android:id="@+id/versesNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/bodySmall"
        app:layout_constraintStart_toStartOf="@id/suraNameEn"
        app:layout_constraintBottom_toBottomOf="@id/suranumber"
        />
    <TextView
        android:id="@+id/suraNameAr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/bodyLarge"
        app:layout_constraintTop_toTopOf="@id/suranumber"
        app:layout_constraintBottom_toBottomOf="@id/suranumber"
        app:layout_constraintEnd_toEndOf="parent"
        />
    <TextView
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        app:layout_constraintTop_toBottomOf="@id/suranumber"
        android:background="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="40dp"
        />

</androidx.constraintlayout.widget.ConstraintLayout>